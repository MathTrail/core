# Platform constants for MathTrail.
# Source of truth for all repos — consumed via COPY --from in Dockerfiles.
# Versioning: semver. Major bump = breaking change (variable removed/renamed).

# Kubernetes namespace used by all services
NAMESPACE=mathtrail

# Kubernetes namespace for observability stack (LGTM, Pyroscope, OTel Collector)
MONITORING_NAMESPACE=monitoring

# Root URL of the Helm chart repository (GitHub Pages site)
CHARTS_REPO_ROOT=https://MathTrail.github.io/charts

# URL of the Helm chart index directory
CHARTS_REPO=https://MathTrail.github.io/charts/charts

# Name of the local k3d Kubernetes cluster
CLUSTER_NAME=k3d-mathtrail-dev

# OCI registry address accessible from the host machine (outside the cluster)
REGISTRY=k3d-mathtrail-registry.localhost:5050

# OCI registry address accessible from pods inside the cluster
REGISTRY_CLUSTER=k3d-mathtrail-registry:5000

# GitHub organization name
GITHUB_ORG=MathTrail

# External domain for Traefik IngressRoute and TLS certificate
# Dev: mathtrail.localhost (resolves to 127.0.0.1, k3d forwards :443 from host)
# Staging/prod: override with real domain (e.g. mathtrail.io)
DOMAIN=mathtrail.localhost
